{
  "name": "historic-input",
  "version": "0.1.1",
  "description": "Historic Input — persist and recall input values per data-history tag using arrow keys",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "future_improvements.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "example": "npm run build && vite examples/vanilla --open",
    "example:preview": "npm run build && vite preview examples/vanilla"
  },
  "keywords": [
    "input",
    "historic",
    "history",
    "localstorage",
    "keyboard",
    "react",
    "angular"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
